{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "name": {
            "$ref": "#/definitions/db_object_name",
            "description": "Name of the database schema"
        },
        "@id": {
            "type": "string",
            "description": "Unique identifier of the database schema"
        },
        "description": {
            "type": "string",
            "description": "Description of the database schema"
        },
        "tables": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "$ref": "#/definitions/db_object_name",
                        "description": "The name of the database table"
                    },
                    "@id": {
                        "type": "string",
                        "description": "Unique identifier of the database table"
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the database table"
                    },
                    "tap:table_index": {
                        "type": "integer",
                        "description": "IVOA TAP table index"
                    },
                    "primaryKey": {
                        "type": "string",
                        "description": "identifier of the primary key column"
                    },
                    "mysql:engine": {
                        "type": "string",
                        "enum": ["MyISAM", "MEMORY", "CSV", "ARCHIVE", "BLACKHOLE", "MERGE", "FEDERATED", "EXAMPLE"],
                        "description": "MySQL storage engine"
                    },
                    "mysql:charset": {
                        "type": "string",
                        "description": "MySQL character set (unconstrained as there are many options)"
                    },
                    "columns": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "$ref": "#/definitions/db_object_name",
                                    "description": "Name of the database column"
                                },
                                "@id": {
                                    "type": "string",
                                    "description": "Unique identifier of the database column"
                                },
                                "datatype": {
                                    "type": "string",
                                    "enum": ["boolean", "byte", "short", "int", "long", "float", "double", "char", "string", "unicode", "text", "binary", "timestamp"],
                                    "description": "Datatype of the database column"
                                },
                                "length": {
                                    "type": "integer",
                                    "description": "Length of the database column",
                                    "minimum": 1
                                },
                                "mysql:datatype": {
                                    "type": "string",
                                    "description": "MySQL datatype of the database column (unconstrained for now due to inclusion of length in parenthesis)"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "Description of the database column"
                                },
                                "nullable": {
                                    "type": "boolean",
                                    "description": "Whether or not the database column is nullable"
                                },
                                "autoincrement": {
                                    "type": "boolean",
                                    "description": "Whether or not the database column is autoincremented"
                                },
                                "value": {
                                    "description": "Default value of the database column"
                                },
                                "tap:column_index": {
                                    "type": "integer",
                                    "description": "IVOA TAP column index"
                                },
                                "tap:principal": {
                                    "type": "integer",
                                    "description": "IVOA TAP principal column index"
                                },
                                "ivoa:ucd": {
                                    "type": "string",
                                    "pattern": "^([a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)*)(;([a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)*))*$",
                                    "description": "IVOA UCD"
                                },
                                "ivoa:unit": {
                                    "type": ["string", "null"],
                                    "description": "IVOA unit (null allowed for now)"
                                },
                                "fits:tunit": {
                                    "type": ["string", "null"],
                                    "description": "FITS TUNIT (null allowed for now)"
                                },
                                "votable:arraysize": {
                                    "type": ["string", "integer"],
                                    "description": "VOTable arraysize"
                                },
                                "tap:std": {
                                    "type": "integer",
                                    "description": "TAP STD (?)"
                                },
                                "votable:utype": {
                                    "type": "string",
                                    "description": "VOTable utype (this could be constrained with a regexp)"
                                }
                            },
                            "required": ["name", "@id", "datatype", "description"],
                            "additionalProperties": false
                        }
                    },
                    "constraints": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Name of constraint"
                                },
                                "@type": {
                                    "type": "string",
                                    "description": "Type of constraint",
                                    "enum": ["ForeignKey"]
                                },
                                "@id": {
                                    "type": "string",
                                    "description": "Unique identifier of constraint"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "Description of constraint"
                                },
                                "columns": {
                                    "type": "array",
                                    "uniqueItems": true,
                                    "contains": {
                                        "type": "string"
                                    },
                                    "description": "List of columns in constraint",
                                    "minItems": 1
                                },
                                "referencedColumns": {
                                    "type": "array",
                                    "uniqueItems": true,
                                    "contains": {
                                        "type": "string"
                                    },
                                    "description": "List of referenced columns in constraint",
                                    "minItems": 1
                                }
                            },
                            "required": ["name", "@type", "@id", "description", "columns", "referencedColumns"]
                        }
                    },
                    "indexes": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Name of index"
                                },
                                "@id": {
                                    "type": "string",
                                    "description": "Unique identifier of index"
                                },
                                "columns": {
                                    "type": "array",
                                    "uniqueItems": true,
                                    "contains": {
                                        "type": "string"
                                    },
                                    "description": "List of referenced columns in constraint",
                                    "minItems": 1
                                }
                            }
                        }
                    }
                },
                "required": ["name", "@id", "description", "columns"],
                "additionalProperties": false
            }
        }
    },
    "required": ["name", "@id", "description", "tables"],
    "definitions": {
        "db_object_name": {
            "type": "string",
            "pattern": "^[_a-zA-Z][_a-zA-Z0-9]*$"
        }
    },
    "additionalProperties": false
}
