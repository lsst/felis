{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "name": {
            "$ref": "#/definitions/db_object_name",
            "description": "The name of the database schema"
        },
        "@id": {"type": "string"},
        "description": {"type": "string"},
        "tables": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "$ref": "#/definitions/db_object_name",
                        "description": "The name of the database table"
                    },
                    "@id": {"type": "string"},
                    "description": {"type": "string"},
                    "tap:table_index": {"type": "integer"},
                    "columns": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "$ref": "#/definitions/db_object_name",
                                    "description": "The name of the database column"
                                },
                                "@id": {
                                    "type": "string",
                                    "description": "The unique identifier of the database column"
                                },
                                "datatype": {
                                    "type": "string",
                                    "enum": ["boolean", "byte", "short", "int", "long", "float", "double", "char", "string", "unicode", "text", "binary"],
                                    "description": "The datatype of the database column"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "The description of the database column"
                                },
                                "nullable": {
                                    "type": "boolean",
                                    "description": "Whether or not the database column is nullable"
                                },
                                "tap:column_index": {
                                    "type": "integer",
                                    "description": "IVOA TAP column index"
                                },
                                "tap:principal": {
                                    "type": "integer",
                                    "description": "IVOA TAP principal column index"
                                },
                                "ivoa:ucd": {
                                    "type": "string",
                                    "pattern": "^([a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)*)(;([a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)*))*$",
                                    "description": "IVOA UCD"
                                }
                            },
                            "required": ["name", "@id", "datatype", "description"]
                        }
                    }
                },
                "required": ["name", "@id", "description", "columns"]
            }
        }
    },
    "required": ["name", "@id", "description", "tables"],
    "definitions": {
        "db_object_name": {
            "type": "string",
            "pattern": "^[_a-zA-Z][_a-zA-Z0-9]*$"
        }
    }
}
