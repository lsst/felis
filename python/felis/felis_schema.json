{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "name": {"type": "string"},
        "@id": {"type": "string"},
        "description": {"type": "string"},
        "tables": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {"type": "string"},
                    "@id": {"type": "string"},
                    "description": {"type": "string"},
                    "tap:table_index": {"type": "integer"},
                    "columns": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {"type": "string"},
                                "@id": {"type": "string"},
                                "datatype": {
                                    "type": "string",
                                    "enum": ["boolean", "byte", "short", "int", "long", "float", "double", "char", "string", "unicode", "text", "binary"]
                                },
                                "description": {"type": "string"},
                                "ivo:ucd": {
                                    "type": "string",
                                    "pattern": "^([a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)*)(;([a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+))*)*$"
                                }
                            },
                            "required": ["name", "@id", "datatype", "description"]
                        }
                    }
                },
                "required": ["name", "@id", "description", "columns"]
            }
        }
    },
    "required": ["name", "@id", "description", "tables"]
}
